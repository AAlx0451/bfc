{S std/stdnum.bfh}

{L func/func.bfh}
{L std/std.bfh}

{D NULL TONULL}
{D NIL TONULL}
{D null TONULL}
{D nil TONULL}

{D SOH +}
{D TOSOH TONULL INCR}

